{
  "name": "sentinel-diff",
  "version": "0.1.0",
  "description": "AI-powered CI/CD tool that analyzes Git PR changes against project rules",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/cli/analyze.ts"
  },
  "keywords": [
    "ci",
    "github",
    "pr",
    "code-review",
    "diff"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@langchain/core": "^1.1.28",
    "@langchain/google-genai": "^2.1.23",
    "@langchain/groq": "^1.1.2",
    "bullmq": "^5.70.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "ioredis": "^5.9.3",
    "pg": "^8.18.0",
    "pgvector": "^0.2.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  }
}
